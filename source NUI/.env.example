# CAD NUI environment variables
# Copy this file to .env (dev) or .env.production (release)

# UI mode
VITE_DOCK_ONLY=true
VITE_UI_MODE=dock

# Mock mode (enable for local browser testing)
VITE_USE_MOCK_DATA=true
VITE_MOCK_BYPASS_ROLE_GUARDS=true
VITE_MOCK_USER_ID=OFFICER_101
VITE_MOCK_USER_BADGE=""
VITE_MOCK_USER_NAME=Officer John Martinez
VITE_MOCK_USER_ROLE=police

# API / NUI base
VITE_API_URL=https://cad-system

# Production recommended values (.env.production)
# VITE_USE_MOCK_DATA=false
# VITE_MOCK_BYPASS_ROLE_GUARDS=false
